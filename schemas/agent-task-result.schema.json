{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentgrid.dev/schemas/agent-task-result.schema.json",
  "title": "AgentTaskResult",
  "description": "Unified structured result for AgentGrid task completion, failure, verification, and evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": ["api_version", "kind", "task_id", "status", "ok", "result", "error", "artifacts"],
  "properties": {
    "api_version": {
      "const": "agentgrid.task-result/v1"
    },
    "kind": {
      "const": "AgentTaskResult"
    },
    "task_id": {
      "$ref": "#/$defs/task_id"
    },
    "job_id": {
      "type": ["string", "null"],
      "pattern": "^job_[A-Za-z0-9_\\-]+$",
      "default": null
    },
    "attempt_id": {
      "type": ["string", "null"],
      "pattern": "^attempt_[A-Za-z0-9_\\-]+$",
      "default": null
    },
    "node_id": {
      "type": ["string", "null"],
      "minLength": 1,
      "default": null
    },
    "tool_id": {
      "type": ["string", "null"],
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:\\-]*$",
      "default": null
    },
    "status": {
      "enum": ["succeeded", "failed", "cancelled", "timed_out", "verification_failed"]
    },
    "ok": {
      "type": "boolean"
    },
    "result": {
      "type": ["object", "array", "string", "number", "boolean", "null"],
      "description": "Tool-specific result payload."
    },
    "error": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_\\-]*$"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "details": {
          "type": ["object", "array", "string", "number", "boolean", "null"]
        },
        "retryable": {
          "type": "boolean",
          "default": false
        }
      },
      "default": null
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      },
      "default": []
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "started_at": {
          "$ref": "#/$defs/nullable_date_time"
        },
        "completed_at": {
          "$ref": "#/$defs/nullable_date_time"
        },
        "duration_ms": {
          "type": ["integer", "null"],
          "minimum": 0,
          "default": null
        },
        "exit_code": {
          "type": ["integer", "null"],
          "default": null
        },
        "stdout_bytes": {
          "type": ["integer", "null"],
          "minimum": 0,
          "default": null
        },
        "stderr_bytes": {
          "type": ["integer", "null"],
          "minimum": 0,
          "default": null
        }
      },
      "default": {}
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "state": {
          "enum": ["not_requested", "passed", "failed", "error"]
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          },
          "default": []
        },
        "summary": {
          "type": ["string", "null"],
          "default": null
        }
      },
      "default": {
        "state": "not_requested",
        "rules": [],
        "summary": null
      }
    },
    "retry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "retryable": {
          "type": "boolean",
          "default": false
        },
        "reason": {
          "type": ["string", "null"],
          "default": null
        },
        "next_attempt_allowed": {
          "type": "boolean",
          "default": false
        }
      },
      "default": {
        "retryable": false,
        "reason": null,
        "next_attempt_allowed": false
      }
    },
    "audit": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/audit_event_ref"
      },
      "default": []
    }
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "enum": ["screenshot", "stdout_log", "stderr_log", "serial_log", "file_artifact", "test_report", "operation_timeline", "json", "other"]
        },
        "name": {
          "type": ["string", "null"],
          "default": null
        },
        "content_type": {
          "type": ["string", "null"],
          "default": null
        },
        "size_bytes": {
          "type": ["integer", "null"],
          "minimum": 0,
          "default": null
        },
        "sha256": {
          "type": ["string", "null"],
          "pattern": "^[a-fA-F0-9]{64}$",
          "default": null
        },
        "url": {
          "type": ["string", "null"],
          "format": "uri",
          "default": null
        }
      }
    },
    "audit_event_ref": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type", "time"],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "time": {
          "type": "string",
          "format": "date-time"
        },
        "summary": {
          "type": "string"
        }
      }
    },
    "nullable_date_time": {
      "type": ["string", "null"],
      "format": "date-time",
      "default": null
    },
    "task_id": {
      "type": "string",
      "pattern": "^task_[A-Za-z0-9_\\-]+$"
    }
  },
  "examples": [
    {
      "api_version": "agentgrid.task-result/v1",
      "kind": "AgentTaskResult",
      "task_id": "task_xxx",
      "job_id": null,
      "attempt_id": null,
      "node_id": "hub-node",
      "tool_id": "command.run",
      "status": "succeeded",
      "ok": true,
      "result": {
        "type": "command_result",
        "exit_code": 0,
        "stdout": "ok\n",
        "stderr": "",
        "duration_ms": 12
      },
      "error": null,
      "artifacts": []
    }
  ]
}
