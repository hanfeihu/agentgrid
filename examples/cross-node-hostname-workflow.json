{
  "name": "跨节点主机名巡检",
  "summary": "依次检查 linux-worker-01 和 linux-worker-02 的 hostname，然后发送 AgentMessage 完成通知。",
  "created_by": "architect-agent",
  "nodes": [
    {
      "id": "jia_hostname",
      "title": "查询 linux-worker-01 主机名",
      "payload": {
        "type": "command",
        "program": "hostname",
        "args": [],
        "timeout_seconds": 30
      },
      "labels": ["compute", "command", "node:linux-worker-01"]
    },
    {
      "id": "huarui_hostname",
      "title": "查询 linux-worker-02 主机名",
      "depends_on": ["jia_hostname"],
      "payload": {
        "type": "command",
        "program": "hostname",
        "args": [],
        "timeout_seconds": 30
      },
      "labels": ["compute", "command", "node:linux-worker-02"]
    },
    {
      "id": "notify",
      "title": "发送巡检完成通知",
      "depends_on": ["huarui_hostname"],
      "payload": {
        "type": "agent_message",
        "from": "workflow-engine",
        "to": ["architect-agent"],
        "message_type": "workflow.hostcheck.completed",
        "subject": "跨节点主机名巡检完成",
        "summary": "linux-worker-01 与 linux-worker-02 已完成 hostname 检查。",
        "payload": {}
      },
      "labels": ["compute", "agentmessage"]
    }
  ]
}
