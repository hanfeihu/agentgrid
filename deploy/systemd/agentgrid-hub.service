[Unit]
Description=AgentGrid Hub MVP
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/agentgrid-hub
Environment=AGENTGRID_HUB_HOST=127.0.0.1
Environment=AGENTGRID_HUB_PORT=20080
Environment=AGENTGRID_HUB_DB=/opt/agentgrid-hub/data/agentgrid-hub.db
ExecStart=/usr/bin/python3 /opt/agentgrid-hub/server.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
